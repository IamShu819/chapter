{
  "appId": "com.chapter.reader",
  "appName": "章章",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1000,
      "backgroundColor": "#2D6A4F"
    },
    "StatusBar": {
      "style": "dark",
      "overlaysWebView": false
    }
  }
}
